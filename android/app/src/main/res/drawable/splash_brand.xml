<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#07111F"
                android:centerColor="#10254A"
                android:endColor="#1A1038" />
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#226EF2FF"
                android:endColor="#00B86BFF" />
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="168dp" android:height="168dp" />
            <solid android:color="#1207111F" />
            <stroke android:width="1dp" android:color="#336EF2FF" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:drawable="@drawable/ic_launcher_foreground" />
</layer-list>
